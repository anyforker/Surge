#!name=网络测速
#!desc=通过面板测试当前网络的下载速率与延迟
#!category=Tools
#!author=cc63
#!homepage=https://github.com/cc63/Surge
#!date=2026-07-24
#!version=1.0.0

[Panel]
网络测速 = script-name=Speed,title="网络测速",update-interval=-1

[Script]
Speed = type=generic,script-path=https://raw.githubusercontent.com/anyforker/Surge/main/module/panel/network-speed.js,argument=title=网络测速&iconfast=bolt&iconmid=hare&iconslow=tortoise&colorlow=#06D6A0&colormid=#FFD166&colorhigh=#EF476F&mb=3
